{
    "name": "elajtech-functions",
    "description": "Cloud Functions for Elajtech - Agora Video Calls & VoIP",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "test": "npm run test:standalone",
        "test:all": "npm run test:standalone && npm run test:emulator",
        "test:emulator": "firebase emulators:exec --config ..\\firebase.json --project elajtech-fc804 --only firestore,auth \"npm run test:emulator:local\"",
        "test:emulator:local": "node scripts/check-emulators.js && jest --config jest.config.js --runInBand",
        "test:standalone": "jest --config jest.config.standalone.js --runInBand",
        "lint": "eslint src --ext .ts",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "agora-access-token": "^2.0.4",
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^5.0.0",
        "node-apn": "^3.0.0",
        "picomatch": "^4.0.4"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "fast-check": "^4.5.3",
        "firebase-functions-test": "^3.1.0",
        "firebase-tools": "^14.4.0",
        "jest": "^30.2.0"
    },
    "private": true
}
